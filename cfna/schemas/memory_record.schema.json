{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cfna/memory_record",
  "title": "MemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "memory_id", "memory_type", "content", "source_ids", "embeddings",
    "structured_repr", "authority_level", "creation_time", "confidence",
    "privacy_scope", "review_status", "consolidation_status"
  ],
  "properties": {
    "memory_id": {"type": "string"},
    "memory_type": {"enum": ["working", "episodic", "semantic", "procedural"]},
    "content": {"type": "string"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "embeddings": {"type": "object"},
    "structured_repr": {"type": "object"},
    "authority_level": {
      "enum": [
        "system_policy", "verified_primary_source", "verified_secondary_source",
        "tool_observation", "user_provided_fact", "model_inference",
        "unverified_external_content", "generated_hypothesis"
      ]
    },
    "creation_time": {"type": "string"},
    "last_verified_time": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "contradiction_links": {"type": "array", "items": {"type": "string"}},
    "evidence_links": {"type": "array", "items": {"type": "string"}},
    "user_scope": {"type": ["string", "null"]},
    "privacy_scope": {"type": "string"},
    "expiration_time": {"type": ["string", "null"]},
    "review_status": {"type": "string"},
    "consolidation_status": {"type": "string"}
  }
}
