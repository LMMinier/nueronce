{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cfna/retrieval_record",
  "title": "RetrievalRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["query_id", "candidate_unit_id", "combined_score"],
  "properties": {
    "query_id": {"type": "string"},
    "candidate_unit_id": {"type": "string"},
    "dense_score": {"type": "number"},
    "sparse_score": {"type": "number"},
    "late_interaction_score": {"type": "number"},
    "goal_score": {"type": "number"},
    "temporal_validity": {"type": "number"},
    "provenance_quality": {"type": "number"},
    "contradiction_penalty": {"type": "number"},
    "combined_score": {"type": "number"},
    "relation_prediction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "support": {"type": "number"},
        "contradict": {"type": "number"},
        "unrelated": {"type": "number"}
      }
    }
  }
}
