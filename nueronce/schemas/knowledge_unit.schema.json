{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nueronce/knowledge_unit",
  "title": "KnowledgeUnit",
  "type": "object",
  "additionalProperties": false,
  "required": ["unit_id", "source_id", "unit_type", "text", "byte_span", "section_path"],
  "properties": {
    "unit_id": {"type": "string"},
    "source_id": {"type": "string"},
    "unit_type": {
      "enum": ["definition", "claim", "evidence", "method", "result", "example", "equation", "code", "caveat"]
    },
    "text": {"type": "string"},
    "byte_span": {"type": "array", "items": {"type": "integer"}, "minItems": 2, "maxItems": 2},
    "section_path": {"type": "array", "items": {"type": "string"}},
    "concepts": {"type": "array", "items": {"type": "string"}},
    "entities": {"type": "array", "items": {"type": "string"}},
    "equations": {"type": "array", "items": {"type": "string"}},
    "code_blocks": {"type": "array", "items": {"type": "string"}},
    "claim_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "contradiction_group": {"type": ["string", "null"]},
    "temporal_scope": {
      "type": ["array", "null"],
      "items": {"type": ["string", "null"]},
      "minItems": 2,
      "maxItems": 2
    },
    "confidence_target": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
